  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.17.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.383.0",
    "next": "16.2.1",
    "react": "^19",
    "react-dom": "^19",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.0.1",
    "daisyui": "^4.12.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wrangler": "^4.77.0"
  }
